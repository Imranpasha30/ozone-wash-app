# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files — never commit real credentials
.env
.env.local
.env.production
.env*.local
.env.client
.env.*

# iOS Firebase credentials (contains server-side private key — do NOT commit)
GoogleService-Info.plist
# Note: google-services.json (Android) is intentionally tracked — it is a
# client-side config file. Firebase/Google explicitly states it is safe to commit.

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
